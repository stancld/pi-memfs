# --- Model (Bedrock) ---
AWS_REGION=eu-central-1
# AWS creds come from your usual AWS auth (SSO / shared profile / instance role),
# or set them explicitly:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- VFS metadata: PostgreSQL ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pi_memfs

# --- VFS blobs: S3 ---
S3_BUCKET=pi-memfs-dev
S3_REGION=eu-central-1
# For local dev against MinIO / localstack, point the client at it:
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
